<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F0F">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1A1A1A"
        android:elevation="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Server section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СЕРВЕР"
            android:textColor="#1A73E8"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://your-vps-ip:3200"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:inputType="textUri"
            android:singleLine="true"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvUrlError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URL сервера, где запущен health-proxy.py. Используй HTTPS для безопасной передачи данных."
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btnTestConnection"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Проверить"
                android:textSize="13sp"
                android:backgroundTint="#333333"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSaveUrl"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Сохранить"
                android:textSize="13sp"
                android:backgroundTint="#1A73E8" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Schedule section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="РАСПИСАНИЕ"
            android:textColor="#1A73E8"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Утро (час)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etMorningHour"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="9"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:background="#1A1A1A"
                    android:padding="12dp"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Вечер (час)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etEveningHour"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="21"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:background="#1A1A1A"
                    android:padding="12dp"
                    android:inputType="number"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveSchedule"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Сохранить расписание"
            android:textSize="13sp"
            android:backgroundTint="#333333"
            android:layout_marginBottom="32dp" />

        <!-- Stats section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222222"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СТАТИСТИКА"
            android:textColor="#1A73E8"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnResetStats"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Сбросить статистику"
            android:textSize="13sp"
            android:backgroundTint="#333333" />

    </LinearLayout>
    </ScrollView>

</LinearLayout>
