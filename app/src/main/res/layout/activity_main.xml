<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0F0F0F">

    <!-- Header: title + settings button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Health Agent"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Настройки"
            android:textSize="12sp"
            android:backgroundTint="#222222"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- Server URL badge -->
    <TextView
        android:id="@+id/tvServerUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ Сервер не настроен — нажми Настройки"
        android:textColor="#FF9800"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ожидание..."
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- Connection status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/viewDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_gray"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvConnection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Samsung Health: не подключено"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Schedule info -->
    <TextView
        android:id="@+id/tvSchedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Расписание: 09:00 и 21:00"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginBottom="20dp" />

    <!-- Send Now button -->
    <Button
        android:id="@+id/btnSendNow"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Отправить сейчас"
        android:textSize="16sp"
        android:backgroundTint="#1A73E8"
        android:layout_marginBottom="12dp" />

    <!-- Permissions button -->
    <Button
        android:id="@+id/btnPermissions"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Разрешения Samsung Health"
        android:textSize="14sp"
        android:backgroundTint="#333333"
        android:layout_marginBottom="20dp" />

    <!-- Log area -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Лог"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A1A"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

</LinearLayout>
