<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block cleartext globally -->
    <base-config cleartextTrafficPermitted="false" />
    <!-- Allow HTTP to our VPS (no HTTPS needed for personal app) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">YOUR_VPS_HOST</domain>
        <!-- Also allow by IP in case DNS fails -->
        <domain includeSubdomains="false">YOUR_VPS_IP</domain>
    </domain-config>
</network-security-config>
