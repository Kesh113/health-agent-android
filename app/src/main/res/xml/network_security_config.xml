<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext HTTP globally — the server URL is entered by the user at runtime
    and may be an HTTP endpoint on a local network or VPS.
    Users who need strict HTTPS can configure it on their server side.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
